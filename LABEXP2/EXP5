        "import socket\n",
        "host = \"127.0.0.1\"\n",
        "ports = [21, 22, 23, 80, 443]\n",
        "print(\"Scanning\", host)\n",
        "for port in ports:\n",
        "    s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)\n",
        "    s.settimeout(1)\n",
        "    result = s.connect_ex((host, port))\n",
        "    if result == 0:\n",
        "        print(\"Port\", port, \"is OPEN\")\n",
        "    else:\n",
        "        print(\"Port\", port, \"is CLOSED\")\n",
        "    s.close()"
      ]
